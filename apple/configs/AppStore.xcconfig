// Mac App Store edition — App Sandbox + security-scoped bookmarks (entitlements
// wired in Phase D via Seshat-AppStore.entitlements). Donate link allowed but
// gated to the US storefront at runtime (Phase D).
PRODUCT_BUNDLE_IDENTIFIER = uk.co.riera.seshat
CODE_SIGN_ENTITLEMENTS = Seshat-AppStore.entitlements
ENABLE_HARDENED_RUNTIME = YES
SWIFT_ACTIVE_COMPILATION_CONDITIONS = $(inherited) EDITION_APPSTORE DONATE_ENABLED
