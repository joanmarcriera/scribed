<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Merged into the generated Info.plist (GENERATE_INFOPLIST_FILE=YES +
       INFOPLIST_FILE, see project.yml). NSAudioCaptureUsageDescription has no
       INFOPLIST_KEY_* build setting, so it must live in a real plist. It is
       the System Audio Recording (Core Audio tap) prompt text. -->
  <key>NSAudioCaptureUsageDescription</key>
  <string>Distavo records the meeting audio playing on this Mac (the other participants) when you choose Record meeting. The audio never leaves your Mac except to the transcription/summary engines you configured.</string>
  <!-- Distavo only uses standard HTTPS/TLS (exempt), so App Store Connect can
       skip the per-build export-compliance question. -->
  <key>ITSAppUsesNonExemptEncryption</key>
  <false/>
</dict>
</plist>
