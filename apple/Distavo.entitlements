<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Direct / Setapp editions are NOT sandboxed. The Mac App Store edition
       uses Distavo-AppStore.entitlements (app-sandbox, network.client,
       files.user-selected.read-write) added in Phase D. -->
  <!-- Hardened-runtime exception: microphone access for the built-in meeting
       recorder. System-audio capture via Core Audio taps needs no entitlement,
       only the user's System Audio Recording TCC approval. -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
